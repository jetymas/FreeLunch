app:
  env: dev

gateway:
  host: "0.0.0.0"
  port: 8000
  workers: 1
  log_level: "info"

database:
  path: "freelunch.db"
  busy_timeout_ms: 5000

providers:
  enabled:
    - openrouter

  openrouter:
    enabled: true
    discovery_enabled: true
    inference_enabled: true
    dev_stub_enabled: false   # Dev-only no-key stub. Ignored outside APP_ENV=dev.
    api_base: "https://openrouter.ai/api/v1"
    active_probe_enabled: true

discovery:
  interval_minutes: 30
  request_timeout_seconds: 15
  leaderboard:
    chatbot_arena:
      enabled: true
      cache_hours: 24
    open_llm:
      enabled: true
      cache_hours: 24

routing:
  default_model: auto
  max_attempts: 3
  enable_request_preference_headers: true

ranking:
  interval_minutes: 15
  fallback_model: "openrouter/openrouter/free"
  weights:
    benchmark_score: 0.30
    real_world_usage: 0.15
    latency: 0.20
    availability: 0.20
    context_window: 0.10
    feature_support: 0.05

health:
  probe_interval_minutes: 180
  probe_timeout_seconds: 15
  probe_concurrency: 1
  max_probes_per_run: 1
  stale_after_minutes: 360
  top_n_stale_probe: 3
  startup_probe_limit: 2
  consecutive_failures_threshold: 3
  cooldown_minutes: 30
  max_backoff_exponent: 4
  probe_max_tokens: 1
  daily_request_budget_by_provider:
    openrouter: 5

logging:
  runtime_enabled: true       # Queue-backed JSON runtime logs emitted on a separate listener thread.
  runtime_verbosity: concise  # concise | verbose | debug
  runtime_queue_size: 1000    # Low-priority runtime records drop before request handling stalls.
  request_log_enabled: true
  log_queue_size: 5000        # Low-priority client logs are lossy under saturation.
  request_log_retention_days: 30
  # Runtime logs are ephemeral process output.
  # SQLite request telemetry is separate and powers health, ranking, and token-estimation review.
